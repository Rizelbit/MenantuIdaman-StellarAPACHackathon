# Server
PORT=3000
NODE_ENV=development

# Passkey / WebAuthn
RP_ID=localhost
RP_NAME=Kirimin
ORIGIN=http://localhost:3000

# Stellar Testnet
STELLAR_NETWORK=testnet
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
HORIZON_URL=https://horizon-testnet.stellar.org
FRIENDBOT_URL=https://friendbot.stellar.org

# USDC Testnet issuer (Circle's official testnet USDC, not ours — see
# DEMO_FUNDER_SECRET_KEY below for how wallets actually get funded)
USDC_ISSUER=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5

# Relayer (OpenZeppelin Channels) — WAJIB, bukan opsional.
# passkey-kit's PasskeyServer.send() selalu butuh relayer terkonfigurasi;
# tanpa ini /wallet/create dan /tx/submit gagal submit on-chain (walau HTTP
# response tetap 200). Launchtube TIDAK dipakai (deprecated/archived, lihat
# sprint/sprint-0-foundation.md S0-11) — generate API key gratis, instan,
# tanpa approval di https://channels.openzeppelin.com/testnet/gen
RELAYER_BASE_URL=https://channels.openzeppelin.com
RELAYER_API_KEY=

# App signer / deployer — WAJIB, jangan commit private key!
# Menandatangani transaksi deploy wallet baru (deploySource di PasskeyKit).
# Ini BUKAN pengganti RELAYER_BASE_URL di atas — submission tetap lewat relayer.
SIGNER_SECRET_KEY=

# Demo receiver (contract address penerima demo, opsional — /tx/build juga
# bisa resolve otomatis ke user lain yang sudah terdaftar di memory store)
DEMO_RECEIVER_CONTRACT=

# Funder untuk isi USDC testnet ke wallet demo (opsional, dipakai
# POST /wallet/:userId/fund). Kita bukan issuer USDC jadi tidak bisa mint —
# funder harus akun yang SUDAH di-fund USDC manual lewat
# https://faucet.circle.com/ (pilih Stellar, isi G-address funder ini).
# Bisa pakai secret key demo-sender yang sudah ada (lihat sprint/CONFIG.md).
DEMO_FUNDER_SECRET_KEY=
