# Server
PORT=3000
NODE_ENV=development

# Passkey / WebAuthn
RP_ID=localhost
RP_NAME=Kirimin
ORIGIN=http://localhost:3000

# Stellar Testnet
STELLAR_NETWORK=testnet
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
HORIZON_URL=https://horizon-testnet.stellar.org
FRIENDBOT_URL=https://friendbot.stellar.org

# Launchtube — DEPRECATED (repo archived, "should not be used for new projects").
# Fee sponsorship dilakukan backend sebagai relayer sendiri via SIGNER_SECRET_KEY
# di bawah, submit langsung ke SOROBAN_RPC_URL. Var ini opsional, hanya isi bila
# migrasi ke OpenZeppelin Channels di kemudian hari. Lihat sprint/sprint-0-foundation.md S0-11.
LAUNCHTUBE_URL=
LAUNCHTUBE_TOKEN=

# Relayer (OpenZeppelin Channels / Launchtube) — fee sponsorship
# Dapatkan dari https://channels.openzeppelin.com/testnet/gen
RELAYER_BASE_URL=
RELAYER_API_KEY=

# App signer / deployer (WAJIB: jangan commit private key!)
SIGNER_SECRET_KEY=

# Demo receiver (contract address penerima demo)
DEMO_RECEIVER_CONTRACT=
